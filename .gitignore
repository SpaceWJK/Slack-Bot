# 환경변수 (토큰 포함 - 절대 커밋 금지)
.env

# 가상환경
venv/

# 로그
*.log

# 런타임 데이터 (체크리스트 상태 등)
data/

# Python 캐시
__pycache__/
*.pyc

# 레거시 대기소
_legacy/

# 런타임 파일
*.pid
*.bak

# 유틸리티 스크립트 (로컬 전용)
scripts/
!scripts/analyze_answer_miss.py
!scripts/system_healthcheck.py
*.vbs

# IDE
.vscode/
.idea/

# 런타임 상태 파일 (mission_state/mission_history/ops_metrics 등)
Slack Bot/mission_state.json
Slack Bot/mission_history.json
Slack Bot/ops_metrics.db
Slack Bot/checklist_state.json

# 로그 디렉토리
logs/

# tools/ 백업 및 작업용
tools/_workspace/
tools/*_backup_*.html
tools/*_taste_test.html
tools/*_prev.zip
tools/S3-Uploader_prev.zip

# tools/mcp-cache-layer/ 백업 — 코드는 추적, 데이터/runtime 제외 (Master 명시 2026-04-28)
# 광역 ignore (data/, scripts/) 예외로 코드 추적
!tools/mcp-cache-layer/scripts/
!tools/mcp-cache-layer/scripts/**/*.py
!tools/mcp-cache-layer/data/
!tools/mcp-cache-layer/data/**
# data/runtime 명시 차단
tools/mcp-cache-layer/cache/
tools/mcp-cache-layer/logs/
tools/mcp-cache-layer/reports/
tools/mcp-cache-layer/gdi-repo/
tools/mcp-cache-layer/tmp/
tools/mcp-cache-layer/venv/
tools/mcp-cache-layer/.pytest_cache/
tools/mcp-cache-layer/scripts/audit_results/
tools/mcp-cache-layer/scripts/__pycache__/
tools/mcp-cache-layer/src/__pycache__/
tools/mcp-cache-layer/tests/__pycache__/
tools/mcp-cache-layer/**/*.db
tools/mcp-cache-layer/**/*.db-shm
tools/mcp-cache-layer/**/*.db-wal
tools/mcp-cache-layer/**/*.bak*
tools/mcp-cache-layer/**/*.pyc
